NODE_ENV=development
PORT=8000
MONGO_URI=mongodb://127.0.0.1:27017/inventory
RECORDS_PER_PAGE=10

# JWT (required in production)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE=1d
COOKIE_EXPIRE=1

# Rate limiting (requests per windowMs)
MAX_API_RATE_LIMIT=100

# SMTP (optional; leave empty to skip sending email)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_MAIL=

# Logging: error | warn | info | debug
LOG_LEVEL=info
